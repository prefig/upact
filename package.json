	},
	"keywords": [
		"identity",
		"identity-port",
		"anti-corruption-layer",
		"ports-and-adapters",
		"privacy-by-design",
		"minimum-disclosure",
		"ulysses-pact",
		"open-social-awards"
	],
	"author": "Theodore Evans (brave.berlin) and upact contributors",
	"repository": {
		"type": "git",
		"url": "https://github.com/prefig/upact"
